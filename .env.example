# Copy this file to `.env` and fill in your own values.
# The application will automatically load `.env` from the project root.

# One or more GitHub tokens separated by commas.
GITHUB_TOKENS=ghp_your_token_1,ghp_your_token_2

# Optional API endpoints.
GITHUB_API_BASE_URL=https://api.github.com
GITHUB_MARKETPLACE_BASE_URL=https://github.com/marketplace
GITHUB_USER_AGENT=GHA-Cascade-Analyzer/0.1

# Concurrency and timeout.
GITHUB_MAX_CONCURRENCY=20
GITHUB_TIMEOUT_SECONDS=30

# Consumer-first sampling parameters.
GHA_TOP_REPOSITORIES=2000
GHA_MIN_STARS=50
GHA_MAX_WORKFLOWS_PER_REPOSITORY=10
GHA_MAX_HISTORY_COMMITS_PER_WORKFLOW=10
GHA_HISTORY_FETCH_CONCURRENCY=3
# Drift-event studies need repeated collection runs over time so that
# `data/refs/ref_observations.jsonl` can accumulate comparable snapshots.

# Output and checkpoint paths.
GHA_OUTPUT_DIR=data
GHA_CHECKPOINT_DB=data/checkpoints.sqlite3
GHA_STATE_DIR=data/state

# Workflow history mode: currently `api` is the stable option.
GHA_WORKFLOW_HISTORY_MODE=api

# Set to true to skip GitHub Marketplace crawling when the site is unreachable.
GHA_SKIP_MARKETPLACE=false

# Analysis defaults to local-only. Enable online recursive expansion only when you explicitly want analysis to fetch remote action definitions.
GHA_ANALYSIS_ONLINE_RECURSIVE_EXPAND=false
GHA_ANALYSIS_REQUIRE_COMPLETE_LOCAL_DATA=true
GHA_ANALYSIS_RECURSIVE_FETCH_CONCURRENCY=8
GHA_ANALYSIS_RECURSIVE_MAX_DEPTH=6
GHA_ANALYSIS_PROGRESS_REPORT_INTERVAL=25

# Git executable path. Use `git` if it is already in PATH.
GHA_GIT_BIN=git
